# Local dev only — copy to `.env` (`cp .env.example .env`). NOT used in production.
# Stable host ports for local tooling (IntelliJ DB connection, pgAdmin).
# docker compose loads `.env` automatically (and so does Spring Boot's docker-compose
# support). Remove/comment a line to fall back to a random free port — see compose.yaml.
POSTGRES_PORT=15432
PGADMIN_PORT=15050
