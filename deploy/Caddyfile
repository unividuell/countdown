# Trust the shared edge (it reaches us over the private `edge` docker network) so this
# inner Caddy PRESERVES the edge's X-Forwarded-Proto=https / X-Forwarded-Host instead of
# overwriting them with the plaintext :80 hop. Without this, core builds an http:// OAuth
# redirect_uri (two-hop scheme loss).
{
	servers {
		trusted_proxies static private_ranges
	}
}

:80 {
	encode zstd gzip

	# Backend paths. `/logout` is listed exact (the SPA POSTs to exactly /logout) AND as
	# `/logout/*`, because `path /logout/*` (slash before `*`) does NOT match the bare /logout.
	# `/login` is NOT listed exact on purpose: /login is the SPA's sign-in PAGE — only its
	# sub-paths (/login/github, /login/oauth2/code/*) are backend, so use `/login/*` only.
	@backend path /api/* /oauth2/* /login/* /logout /logout/*

	# API paths -> backend. A dedicated handle block (not a bare reverse_proxy) so it is
	# mutually exclusive with the SPA catch-all and evaluated first; otherwise the catch-all
	# handle matches everything (incl. /api/*) and the file_server swallows API requests.
	handle @backend {
		reverse_proxy core:8080
	}

	# everything else -> SPA with HTML5 history-mode fallback
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
